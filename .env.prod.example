# Copier en `.env` à la racine du repo (à côté de docker-compose.prod.yaml)
# et compléter. Ne JAMAIS committer le fichier .env réel (déjà gitignoré).

# Laravel
APP_KEY=
APP_URL=http://crm.thara-services.mg/planning

# MySQL
DB_DATABASE=thara_planning
DB_USERNAME=thara_planning
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Mail (diffusion des plannings)
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=mail.thara-services.mg
MAIL_PORT=587
MAIL_USERNAME=contact@thara-services.mg
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=contact@thara-services.mg

# URL de l'API vue depuis le navigateur (même domaine que le frontend, donc
# pas de souci de CORS en prod)
NEXT_PUBLIC_API_URL=http://crm.thara-services.mg/planning/api

# Port exposé par le conteneur "gateway" sur l'hôte. Le reverse proxy déjà en
# place sur le serveur pour crm.thara-services.mg doit relayer /planning vers
# http://127.0.0.1:<PUBLIC_PORT>/planning (voir docs/DEPLOYMENT.md).
PUBLIC_PORT=8080
